<script>
// ============================
//  STATE
// ============================
let products = JSON.parse(localStorage.getItem('catalog_products') || '[]');
let cart = {}; // productId -> qty
let currentMode = 'admin';

// ============================
//  INIT — check URL params
// ============================
window.onload = () => {
  const params = new URLSearchParams(location.search);
  const mode = params.get('mode');
  const order = params.get('order');

  if (order) {
    showOrderConfirmation(order);
    return;
  }

  if (mode === 'catalog') {
    document.getElementById('main-topbar').style.display = 'none';
    setMode('catalog');
  } else {
    renderAdmin();
    updateShareLink();
  }
};

// ============================
//  MODE
// ============================
function setMode(m) {
  currentMode = m;
  document.querySelectorAll('.mode-btn').forEach((b, i) => {
    b.classList.toggle('active', (i === 0 && m === 'admin') || (i === 1 && m === 'catalog'));
  });
  document.getElementById('admin-view').classList.toggle('active', m === 'admin');
  document.getElementById('catalog-view').classList.toggle('active', m === 'catalog');

  if (m === 'catalog') renderCatalog();
  if (m === 'admin') renderAdmin();
}

// ============================
//  ADMIN
// ============================
function previewImage(input) {
  const file = input.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = e => {
    const img = document.getElementById('preview-img');
    img.src = e.target.result;
    img.style.display = 'block';
    document.getElementById('upload-hint').style.display = 'none';
  };
  reader.readAsDataURL(file);
}

function addProduct() {
  const name = document.getElementById('prod-name').value.trim();
  const price = parseFloat(document.getElementById('prod-price').value);
  const imgFile = document.getElementById('prod-image').files[0];

  if (!name) { alert('נא להזין שם מוצר'); return; }
  if (!price || price <= 0) { alert('נא להזין מחיר תקין'); return; }

  const addToList = (imageData) => {
    const product = {
      id: Date.now().toString(),
      name,
      price,
      image: imageData || null
    };
    products.push(product);
    saveProducts();
    renderAdmin();
    updateShareLink();

    // Reset form
    document.getElementById('prod-name').value = '';
    document.getElementById('prod-price').value = '';
    document.getElementById('prod-image').value = '';
    document.getElementById('preview-img').style.display = 'none';
    document.getElementById('upload-hint').style.display = 'block';
  };

  if (imgFile) {
    const reader = new FileReader();
    reader.onload = e => addToList(e.target.result);
    reader.readAsDataURL(imgFile);
  } else {
    addToList(null);
  }
}

function deleteProduct(id) {
  products = products.filter(p => p.id !== id);
  delete cart[id];
  saveProducts();
  renderAdmin();
  updateShareLink();
}

function renderAdmin() {
  const list = document.getElementById('admin-products-list');
  const count = document.getElementById('prod-count');
  count.textContent = `${products.length} מוצרים`;

  if (products.length === 0) {
    list.innerHTML = '<div class="empty-state">עדיין אין מוצרים — הוסף את הראשון! 👆</div>';
    return;
  }

  list.innerHTML = products.map(p => `
    <div class="admin-product-row">
      ${p.image
        ? `<img class="admin-product-img" src="${p.image}" alt="${p.name}" />`
        : `<div class="admin-product-img placeholder">🛍️</div>`
      }
      <div class="admin-product-info">
        <div class="admin-product-name">${p.name}</div>
        <div class="admin-product-price">₪${p.price.toFixed(2)}</div>
      </div>
      <button class="btn btn-danger" onclick="deleteProduct('${p.id}')">מחק</button>
    </div>
  `).join('');
}

function updateShareLink() {
  const box = document.getElementById('share-link-box');
  if (products.length === 0) { box.style.display = 'none'; return; }
  box.style.display = 'flex';
  const url = location.origin + location.pathname + '?mode=catalog';
  document.getElementById('share-url-text').textContent = url;
}

function copyLink() {
  const url = location.origin + location.pathname + '?mode=catalog';
  navigator.clipboard.writeText(url).then(() => {
    const btn = document.getElementById('copy-btn');
    btn.textContent = '✅ הועתק!';
    btn.classList.add('copied');
    setTimeout(() => { btn.textContent = 'העתק קישור'; btn.classList.remove('copied'); }, 2000);
  });
}

// ============================
//  CATALOG
// ============================
function renderCatalog() {
  const grid = document.getElementById('catalog-grid');
  const empty = document.getElementById('empty-catalog');

  if (products.length === 0) {
    grid.style.display = 'none';
    empty.style.display = 'block';
    return;
  }

  grid.style.display = 'grid';
  empty.style.display = 'none';

  grid.innerHTML = products.map(p => {
    const qty = cart[p.id] || 0;
    return `
      <div class="product-card ${qty > 0 ? 'selected' : ''}" id="card-${p.id}" onclick="toggleProduct('${p.id}')">
        <div class="product-card-select">${qty > 0 ? '✓' : ''}</div>
        ${p.image
          ? `<img class="product-card-img" src="${p.image}" alt="${p.name}" />`
          : `<div class="product-card-img placeholder">🛍️</div>`
        }
        <div class="product-card-body">
          <div class="product-card-name">${p.name}</div>
          <div class="product-card-price">₪${p.price.toFixed(2)}</div>
          ${qty > 0 ? `
            <div class="qty-control" onclick="event.stopPropagation()">
              <button class="qty-btn" onclick="changeQty('${p.id}', -1)">−</button>
              <span class="qty-num">${qty}</span>
              <button class="qty-btn" onclick="changeQty('${p.id}', 1)">+</button>
            </div>
          ` : ''}
        </div>
      </div>
    `;
  }).join('');

  updateCartBar();
}

function toggleProduct(id) {
  if (cart[id]) {
    delete cart[id];
  } else {
    cart[id] = 1;
  }
  renderCatalog();
}

function changeQty(id, delta) {
  const newQty = (cart[id] || 0) + delta;
  if (newQty <= 0) delete cart[id];
  else cart[id] = newQty;
  renderCatalog();
}

function updateCartBar() {
  const bar = document.getElementById('cart-bar');
  const count = document.getElementById('cart-count');
  const summary = document.getElementById('cart-summary');

  const totalItems = Object.values(cart).reduce((a, b) => a + b, 0);
  const totalPrice = Object.entries(cart).reduce((sum, [id, qty]) => {
    const p = products.find(p => p.id === id);
    return sum + (p ? p.price * qty : 0);
  }, 0);

  count.textContent = totalItems;
  summary.textContent = totalItems > 0 ? `סל קניות • ₪${totalPrice.toFixed(2)}` : 'לסל הקניות';

  bar.classList.toggle('visible', totalItems > 0);
}

// ============================
//  ORDER
// ============================
function openOrder() {
  if (Object.keys(cart).length === 0) return;
  const overlay = document.getElementById('order-overlay');
  overlay.classList.add('open');

  const list = document.getElementById('order-items-list');
  let total = 0;

  list.innerHTML = Object.entries(cart).map(([id, qty]) => {
    const p = products.find(p => p.id === id);
    if (!p) return '';
    const sub = p.price * qty;
    total += sub;
    return `
      <div class="order-item">
        ${p.image
          ? `<img class="order-item-img" src="${p.image}" alt="${p.name}" />`
          : `<div class="order-item-img placeholder">🛍️</div>`
        }
        <div class="order-item-info">
          <div class="order-item-name">${p.name}</div>
          <div class="order-item-sub">${qty} × ₪${p.price.toFixed(2)}</div>
        </div>
        <div style="font-weight:700; color: var(--accent)">₪${sub.toFixed(2)}</div>
      </div>
    `;
  }).join('');

  document.getElementById('order-total-price').textContent = `₪${total.toFixed(2)}`;
}

function closeOrderIfOutside(e) {
  if (e.target === document.getElementById('order-overlay')) {
    document.getElementById('order-overlay').classList.remove('open');
  }
}

function sendOrder() {
  const name = document.getElementById('order-name').value.trim();
  const phone = document.getElementById('order-phone').value.trim();
  const email = document.getElementById('order-email').value.trim();
  const notes = document.getElementById('order-notes').value.trim();

  if (!name) { alert('נא להזין שם'); return; }
  if (!phone) { alert('נא להזין טלפון'); return; }

  // Build order object
  const items = Object.entries(cart).map(([id, qty]) => {
    const p = products.find(p => p.id === id);
    return { name: p.name, price: p.price, qty };
  });

  const orderData = { name, phone, email, notes, items, date: new Date().toLocaleString('he-IL') };
  const encoded = btoa(encodeURIComponent(JSON.stringify(orderData)));

  // Create order link
  const orderUrl = location.origin + location.pathname + '?order=' + encoded;

  // Show confirmation
  document.getElementById('order-overlay').classList.remove('open');
  showOrderConfirmation(encoded);

  // Also open whatsapp/email with order link (optional auto-share)
  // Optionally could open: window.open('mailto:?subject=הזמנה חדשה&body=' + encodeURIComponent(orderUrl));
}

function showOrderConfirmation(encoded) {
  try {
    const orderData = JSON.parse(decodeURIComponent(atob(encoded)));
    document.getElementById('main-topbar').style.display = 'none';
    document.getElementById('admin-view').style.display = 'none';
    document.getElementById('catalog-view').style.display = 'none';
    document.getElementById('cart-bar').style.display = 'none';
    document.getElementById('link-view').style.display = 'flex';

    const total = orderData.items.reduce((s, i) => s + i.price * i.qty, 0);
    const box = document.getElementById('order-summary-box');

    box.innerHTML = `
      <div class="summary-row"><span>לקוח</span><span>${orderData.name}</span></div>
      <div class="summary-row"><span>טלפון</span><span>${orderData.phone}</span></div>
      ${orderData.email ? `<div class="summary-row"><span>אימייל</span><span>${orderData.email}</span></div>` : ''}
      <div class="summary-row"><span>תאריך</span><span>${orderData.date}</span></div>
      <div style="height:8px"></div>
      ${orderData.items.map(i => `
        <div class="summary-row">
          <span>${i.name}</span>
          <span>${i.qty} × ₪${i.price.toFixed(2)}</span>
        </div>
      `).join('')}
      ${orderData.notes ? `<div class="summary-row"><span>הערות</span><span style="color:var(--muted)">${orderData.notes}</span></div>` : ''}
      <div style="height:8px"></div>
      <div class="summary-row summary-total"><span>סה"כ</span><span>₪${total.toFixed(2)}</span></div>
    `;
  } catch(e) {
    document.getElementById('link-view').innerHTML = '<div style="color:var(--muted)">שגיאה בטעינת ההזמנה</div>';
  }
}

function saveProducts() {
  // Save only name/price/id (not images – they could be large; image stays in memory for demo)
  localStorage.setItem('catalog_products', JSON.stringify(products));
}
</script>

