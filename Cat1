<!DOCTYPE html>

<html lang="he" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>קטלוג מוצרים</title>
<link href="https://fonts.googleapis.com/css2?family=Heebo:wght@300;400;500;700;900&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0f0f0f;
    --surface: #1a1a1a;
    --surface2: #242424;
    --accent: #f5c518;
    --accent2: #ff6b35;
    --text: #f0ede8;
    --muted: #888;
    --border: #2e2e2e;
    --radius: 12px;
    --success: #4ade80;
  }

- { margin: 0; padding: 0; box-sizing: border-box; }

body {
font-family: ‘Heebo’, sans-serif;
background: var(–bg);
color: var(–text);
min-height: 100vh;
}

/* ===== TOP BAR ===== */
.topbar {
background: var(–surface);
border-bottom: 1px solid var(–border);
padding: 14px 24px;
display: flex;
align-items: center;
justify-content: space-between;
position: sticky;
top: 0;
z-index: 100;
}

.logo {
font-size: 1.3rem;
font-weight: 900;
letter-spacing: -0.5px;
}
.logo span { color: var(–accent); }

.mode-toggle {
display: flex;
gap: 8px;
}

.mode-btn {
background: none;
border: 1px solid var(–border);
color: var(–muted);
padding: 6px 16px;
border-radius: 20px;
cursor: pointer;
font-family: ‘Heebo’, sans-serif;
font-size: 0.85rem;
transition: all 0.2s;
}

.mode-btn.active {
background: var(–accent);
border-color: var(–accent);
color: #000;
font-weight: 700;
}

/* ===== VIEWS ===== */
.view { display: none; padding: 32px 24px; max-width: 1100px; margin: 0 auto; }
.view.active { display: block; }

/* ===== ADMIN ===== */
.admin-grid {
display: grid;
grid-template-columns: 380px 1fr;
gap: 32px;
align-items: start;
}

.card {
background: var(–surface);
border: 1px solid var(–border);
border-radius: var(–radius);
padding: 24px;
}

.card-title {
font-size: 1rem;
font-weight: 700;
margin-bottom: 20px;
color: var(–accent);
text-transform: uppercase;
letter-spacing: 1px;
font-size: 0.8rem;
}

.form-group { margin-bottom: 16px; }

label {
display: block;
font-size: 0.85rem;
color: var(–muted);
margin-bottom: 6px;
}

input[type=“text”], input[type=“number”] {
width: 100%;
background: var(–surface2);
border: 1px solid var(–border);
color: var(–text);
padding: 10px 14px;
border-radius: 8px;
font-family: ‘Heebo’, sans-serif;
font-size: 0.95rem;
transition: border-color 0.2s;
}

input:focus { outline: none; border-color: var(–accent); }

.image-upload-area {
width: 100%;
height: 140px;
border: 2px dashed var(–border);
border-radius: 8px;
display: flex;
flex-direction: column;
align-items: center;
justify-content: center;
cursor: pointer;
transition: all 0.2s;
position: relative;
overflow: hidden;
background: var(–surface2);
}

.image-upload-area:hover { border-color: var(–accent); }

.image-upload-area input {
position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%;
}

.image-upload-area img {
width: 100%; height: 100%; object-fit: cover; position: absolute; inset: 0;
}

.upload-hint { color: var(–muted); font-size: 0.85rem; text-align: center; pointer-events: none; }
.upload-hint strong { display: block; font-size: 1.8rem; margin-bottom: 4px; }

.btn {
width: 100%;
padding: 12px;
background: var(–accent);
color: #000;
border: none;
border-radius: 8px;
font-family: ‘Heebo’, sans-serif;
font-size: 1rem;
font-weight: 700;
cursor: pointer;
transition: transform 0.15s, opacity 0.15s;
}

.btn:hover { opacity: 0.9; transform: translateY(-1px); }
.btn:active { transform: translateY(0); }

.btn-danger {
background: none;
border: 1px solid #ff4444;
color: #ff4444;
font-size: 0.8rem;
padding: 6px 12px;
width: auto;
border-radius: 6px;
}

/* ===== PRODUCT LIST (admin) ===== */
.products-header {
display: flex;
align-items: center;
justify-content: space-between;
margin-bottom: 16px;
}

.products-count {
font-size: 0.85rem;
color: var(–muted);
}

.admin-products {
display: flex;
flex-direction: column;
gap: 12px;
}

.admin-product-row {
background: var(–surface2);
border: 1px solid var(–border);
border-radius: 10px;
display: flex;
align-items: center;
gap: 14px;
padding: 12px 16px;
animation: fadeIn 0.3s ease;
}

@keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: none; } }

.admin-product-img {
width: 56px; height: 56px; border-radius: 8px; object-fit: cover;
background: var(–border);
flex-shrink: 0;
}

.admin-product-img.placeholder {
display: flex; align-items: center; justify-content: center;
font-size: 1.4rem; background: var(–surface);
}

.admin-product-info { flex: 1; }
.admin-product-name { font-weight: 600; font-size: 0.95rem; }
.admin-product-price { color: var(–accent); font-size: 0.85rem; margin-top: 2px; }

.empty-state {
text-align: center;
color: var(–muted);
padding: 40px 20px;
font-size: 0.9rem;
}

/* ===== CATALOG (customer) ===== */
.catalog-header {
margin-bottom: 28px;
display: flex;
align-items: flex-end;
justify-content: space-between;
flex-wrap: wrap;
gap: 12px;
}

.catalog-title {
font-size: 2rem;
font-weight: 900;
letter-spacing: -1px;
}

.catalog-title span { color: var(–accent); }

.catalog-grid {
display: grid;
grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
gap: 20px;
margin-bottom: 32px;
}

.product-card {
background: var(–surface);
border: 1px solid var(–border);
border-radius: var(–radius);
overflow: hidden;
cursor: pointer;
transition: transform 0.2s, border-color 0.2s;
position: relative;
}

.product-card:hover { transform: translateY(-4px); border-color: var(–accent); }

.product-card.selected {
border-color: var(–accent);
box-shadow: 0 0 0 2px var(–accent);
}

.product-card-img {
width: 100%; height: 180px; object-fit: cover; display: block;
background: var(–surface2);
}

.product-card-img.placeholder {
display: flex; align-items: center; justify-content: center;
font-size: 3rem; background: var(–surface2);
}

.product-card-body { padding: 14px; }
.product-card-name { font-weight: 700; font-size: 1rem; margin-bottom: 6px; }
.product-card-price { color: var(–accent); font-weight: 600; }

.product-card-select {
position: absolute;
top: 10px;
left: 10px;
width: 28px; height: 28px;
border-radius: 50%;
background: var(–surface);
border: 2px solid var(–border);
display: flex; align-items: center; justify-content: center;
font-size: 0.9rem;
transition: all 0.2s;
}

.product-card.selected .product-card-select {
background: var(–accent);
border-color: var(–accent);
color: #000;
}

.qty-control {
display: flex; align-items: center; gap: 8px; margin-top: 10px;
}

.qty-btn {
width: 28px; height: 28px; border-radius: 50%;
background: var(–surface2); border: 1px solid var(–border);
color: var(–text); cursor: pointer; font-size: 1rem;
display: flex; align-items: center; justify-content: center;
transition: background 0.15s;
}

.qty-btn:hover { background: var(–accent); color: #000; border-color: var(–accent); }

.qty-num { font-weight: 700; min-width: 20px; text-align: center; }

/* ===== CART BAR ===== */
.cart-bar {
position: fixed;
bottom: 24px;
left: 50%;
transform: translateX(-50%) translateY(80px);
background: var(–accent);
color: #000;
border-radius: 50px;
padding: 14px 28px;
display: flex;
align-items: center;
gap: 16px;
box-shadow: 0 8px 32px rgba(245,197,24,0.4);
transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
cursor: pointer;
font-family: ‘Heebo’, sans-serif;
border: none;
font-size: 1rem;
font-weight: 700;
z-index: 200;
white-space: nowrap;
}

.cart-bar.visible { transform: translateX(-50%) translateY(0); }
.cart-bar:hover { opacity: 0.92; }

.cart-count {
background: #000;
color: var(–accent);
border-radius: 50%;
width: 26px; height: 26px;
display: flex; align-items: center; justify-content: center;
font-size: 0.85rem;
font-weight: 900;
}

/* ===== ORDER MODAL ===== */
.overlay {
display: none;
position: fixed; inset: 0;
background: rgba(0,0,0,0.8);
z-index: 300;
align-items: flex-end;
justify-content: center;
}

.overlay.open { display: flex; }

.order-sheet {
background: var(–surface);
border-radius: 20px 20px 0 0;
padding: 28px 24px;
width: 100%;
max-width: 560px;
max-height: 90vh;
overflow-y: auto;
animation: slideUp 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes slideUp { from { transform: translateY(100%); } to { transform: none; } }

.sheet-title {
font-size: 1.3rem;
font-weight: 900;
margin-bottom: 20px;
}

.order-item {
display: flex; align-items: center; gap: 12px;
padding: 10px 0;
border-bottom: 1px solid var(–border);
}

.order-item-img {
width: 44px; height: 44px; border-radius: 8px; object-fit: cover;
background: var(–surface2); flex-shrink: 0;
}

.order-item-img.placeholder {
display: flex; align-items: center; justify-content: center; font-size: 1.2rem;
}

.order-item-info { flex: 1; }
.order-item-name { font-weight: 600; font-size: 0.9rem; }
.order-item-sub { color: var(–muted); font-size: 0.8rem; }

.order-total {
display: flex; justify-content: space-between; align-items: center;
padding: 16px 0 20px;
font-size: 1.1rem;
font-weight: 700;
}

.order-total-price { color: var(–accent); font-size: 1.3rem; }

.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }

.btn-send {
background: var(–accent2);
margin-top: 8px;
}

/* ===== ORDER LINK VIEW ===== */
#link-view {
min-height: 100vh;
display: flex;
flex-direction: column;
align-items: center;
justify-content: center;
text-align: center;
padding: 32px;
}

.link-icon { font-size: 4rem; margin-bottom: 16px; }

.link-title { font-size: 2rem; font-weight: 900; margin-bottom: 8px; }
.link-sub { color: var(–muted); margin-bottom: 24px; }

.order-summary-box {
background: var(–surface);
border: 1px solid var(–border);
border-radius: var(–radius);
padding: 20px;
max-width: 420px;
width: 100%;
text-align: right;
}

.summary-row {
display: flex; justify-content: space-between;
padding: 6px 0;
font-size: 0.9rem;
border-bottom: 1px solid var(–border);
}

.summary-row:last-child { border-bottom: none; }
.summary-total { font-weight: 700; font-size: 1rem; color: var(–accent); }

/* ===== SHARE LINK ===== */
.share-link-box {
background: var(–surface2);
border: 1px solid var(–border);
border-radius: 8px;
padding: 12px 16px;
display: flex;
gap: 10px;
align-items: center;
margin-top: 16px;
width: 100%;
max-width: 520px;
}

.share-link-url {
flex: 1;
color: var(–accent);
font-size: 0.8rem;
word-break: break-all;
font-family: monospace;
}

.copy-btn {
background: var(–surface);
border: 1px solid var(–border);
color: var(–text);
padding: 6px 14px;
border-radius: 6px;
cursor: pointer;
font-family: ‘Heebo’, sans-serif;
font-size: 0.82rem;
white-space: nowrap;
transition: background 0.15s;
flex-shrink: 0;
}

.copy-btn:hover { background: var(–accent); color: #000; border-color: var(–accent); }
.copy-btn.copied { background: var(–success); color: #000; border-color: var(–success); }

.empty-catalog {
text-align: center;
padding: 80px 20px;
color: var(–muted);
}

.empty-catalog .big { font-size: 3rem; margin-bottom: 12px; }
.empty-catalog p { font-size: 0.95rem; }

@media (max-width: 700px) {
.admin-grid { grid-template-columns: 1fr; }
.catalog-grid { grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); }
.form-row { grid-template-columns: 1fr; }
}
</style>

</head>
